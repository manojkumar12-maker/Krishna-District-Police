# Copy this file to .env and update the values
PORT=3000
JWT_SECRET=change-this-to-a-random-secret-string
NODE_ENV=production

# Initial admin account (used only on first run when no users exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# MongoDB Atlas connection string
# Get this from: MongoDB Atlas > Database > Connect > Drivers
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/krishna-police?retryWrites=true&w=majority