# Cloudflare Worker + D1 - Local Development Variables
# Copy this to .dev.vars for local dev, or use `wrangler secret put` for production.

# ── Authentication ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-change-me

# ── Default Admin User (seeded on first request) ────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password
